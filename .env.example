# Paramètres de connexion PostgreSQL pour AquaReco
# Copiez ce fichier en .env et renseignez vos valeurs
# Le fichier .env ne doit JAMAIS être committé dans git

DB_HOST=localhost
DB_PORT=5432
DB_NAME=aquareco
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# Optionnel : niveau de log (DEBUG / INFO / WARNING)
LOG_LEVEL=INFO
